header:not(.fixed) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
}

header:not(.fixed) > div:nth-child(1) {
    display: none;
}

header:not(.fixed) > div:nth-child(2) {
    position: absolute !important;
    background: transparent !important;
    box-shadow: unset !important;
}

header:not(.fixed) > div:nth-child(2) img {
    content: url('https://thoppelevadores.com.br/wp-content/uploads/2025/10/logo-white-scaled.webp');
}

header:not(.fixed) > div:nth-child(2) .elementor-nav-menu--main .elementor-item {
    color: #fff !important;
}

header:not(.fixed) > div:nth-child(2) .elementor-menu-toggle svg {
    fill: #fff !important;
}

header:not(.fixed) > div:nth-child(2) .elementor-item::after {
    background-color: #fff !important;
}/* End custom CSS */
